# AgentForge Environment Variables Template
# All paths below are relative to the project root where this .env file should be placed.

# [Mandatory] AI Model API Keys
# OPENAI_API_KEY is mapped internally as MODEL_API_KEY
MODEL_API_KEY=sk-your-key-here

# [Mandatory] Database Connection
# For Docker: Use service name 'postgres' (e.g., postgresql://user:pass@postgres:5432/agentforge)
# For Local: Use 'localhost'
DB_URL=postgresql://user:password@localhost:5432/agentforge

# [Mandatory] Redis Connection
# For Docker: Use service name 'redis' (e.g., redis://redis:6379/0)
# For Local: Use 'localhost'
REDIS_URL=redis://localhost:6379/0

# [Optional] Application Settings
ENV=dev
APP_NAME=AgentForge
LOG_LEVEL=INFO
# Relative path from project root to config.yaml
CONFIG_PATH=backend/config.yaml
