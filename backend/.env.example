# AgentForge Environment Variables Template
# All paths below are relative to the project root where this .env file should be placed.

# [Mandatory] AI Model API Keys
# Dev default provider: OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Backward-compatible fields (optional if OPENROUTER_* is configured)
MODEL_API_KEY=
MODEL_BASE_URL=https://openrouter.ai/api/v1

# [Mandatory] Database Connection
# For Docker: Use service name 'postgres' (e.g., postgresql+asyncpg://user:pass@postgres:5432/agentforge)
# For Local: Use 'localhost'
DB_URL=postgresql+asyncpg://user:password@localhost:5432/agentforge

# [Mandatory] Redis Connection
# For Docker: Use service name 'redis' (e.g., redis://redis:6379/0)
# For Local: Use 'localhost'
REDIS_URL=redis://localhost:6379/0

# [Optional] Application Settings
ENV=dev
APP_NAME=AgentForge
LOG_LEVEL=INFO
# Relative path from project root to config.yaml
CONFIG_PATH=backend/config.yaml

# [Auth]
AUTH_DEV_BYPASS_ENABLED=false
AUTH_DEV_USER_ID=dev-user
AUTH_DEV_TEAM_ID=00000000-0000-0000-0000-000000000001
AUTH_DEV_ROLE=developer
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
REGISTRATION_TOKEN_TTL_SECONDS=1800
SEARCH_ID_MIN=10000000
SEARCH_ID_MAX=99999999
DEFAULT_TEAM_TOKEN_LIMIT=1000000
DEFAULT_TEAM_RATE_LIMIT=100

# [SMTP]
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=2049252009@qq.com
SMTP_PASSWORD=hhxublywftttcagf
SMTP_FROM_EMAIL=2049252009@qq.com
SMTP_FROM_NAME=EyesCloud
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=5
EMAIL_DELIVERY_MODE=smtp

# [Avatar Storage]
AVATAR_STORAGE_PROVIDER=local
AVATAR_PUBLIC_BASE_URL=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_USE_SSL=true
OBJECT_STORAGE_VERIFY_TLS=true
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_PUBLIC_READ=true
EMAIL_VERIFICATION_CODE_TTL_SECONDS=600
PASSWORD_RESET_CODE_TTL_SECONDS=600
EMAIL_SEND_RATE_LIMIT_SECONDS=60
EMAIL_SEND_MAX_RETRIES=3
EMAIL_SEND_RETRY_DELAYS_SECONDS=1,3
